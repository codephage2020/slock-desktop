{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slock Desktop",
  "version": "0.2.11",
  "identifier": "ai.slock.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "slock-desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "backgroundColor": [247, 247, 245, 255],
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 19
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGOTg5NUVDRDZGNEE3MDQKUldRRXAvVFc3SldZbjNSNzRCWEZIRmFkcEJxam5RYlQ3dlBSc1hNcWNsRkkya0Z3ZUxPL0NGTGQK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["slock"]
      }
    }
  }
}
