{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slock Desktop",
  "version": "0.1.0",
  "identifier": "ai.slock.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "slock-desktop",
        "width": 800,
        "height": 460,
        "minWidth": 720,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "backgroundColor": [0, 0, 0, 0],
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 19
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": ""
    }
  }
}
