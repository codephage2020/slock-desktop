{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "remote": {
    "urls": ["https://app.slock.ai", "https://app.slock.ai/*"]
  },
  "windows": [
    "main",
    "auth"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "deep-link:default",
    "opener:allow-default-urls"
  ]
}
